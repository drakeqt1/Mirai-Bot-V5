{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    { "src": "/health", "dest": "index.js" },
    { "src": "/api/(.*)", "dest": "index.js" },
    { "src": "/(.*)", "dest": "index.js" }
  ],
  "env": {
    "VERCEL": "1",
    "NODE_ENV": "production"
  },
  "functions": {
    "index.js": {
      "maxDuration": 60,
      "memory": 1024
    }
  }
}
